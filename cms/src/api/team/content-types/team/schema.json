{
  "kind": "collectionType",
  "collectionName": "teams",
  "info": {
    "singularName": "team",
    "pluralName": "teams",
    "displayName": "Team",
    "description": "Career team or subgroup"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "sortOrder": {
      "type": "integer",
      "default": 999
    },
    "pillar": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::pillar.pillar",
      "inversedBy": "teams"
    },
    "careers": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::career.career",
      "mappedBy": "team"
    }
  }
}
