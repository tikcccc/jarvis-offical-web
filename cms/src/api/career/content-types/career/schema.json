{
  "kind": "collectionType",
  "collectionName": "careers",
  "info": {
    "singularName": "career",
    "pluralName": "careers",
    "displayName": "24 招聘｜职位",
    "description": "官网公开展示的职位"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "config": {
    "settings": {
      "bulkable": true,
      "filterable": true,
      "mainField": "title",
      "defaultSortBy": "sortOrder",
      "defaultSortOrder": "ASC",
      "pageSize": 10,
      "searchable": true,
      "relationOpenMode": "modal"
    },
    "metadatas": {
      "title": {
        "edit": {
          "label": "职位名称"
        },
        "list": {
          "label": "职位名称"
        }
      },
      "slug": {
        "edit": {
          "label": "URL 标识",
          "description": "用于页面链接；可留空，保存时会自动生成如 career-1 的值，也可手动覆写"
        },
        "list": {
          "label": "URL 标识"
        }
      },
      "team": {
        "edit": {
          "label": "所属团队"
        },
        "list": {
          "label": "所属团队"
        }
      },
      "employmentType": {
        "edit": {
          "label": "雇佣类型"
        },
        "list": {
          "label": "雇佣类型"
        }
      },
      "locations": {
        "edit": {
          "label": "工作地点"
        },
        "list": {
          "label": "工作地点"
        }
      },
      "workModel": {
        "edit": {
          "label": "工作模式"
        },
        "list": {
          "label": "工作模式"
        }
      },
      "postedAt": {
        "edit": {
          "label": "发布时间"
        },
        "list": {
          "label": "发布时间"
        }
      },
      "expiresAt": {
        "edit": {
          "label": "截止时间"
        },
        "list": {
          "label": "截止时间"
        }
      },
      "experienceLevel": {
        "edit": {
          "label": "经验级别"
        },
        "list": {
          "label": "经验级别"
        }
      },
      "sortOrder": {
        "edit": {
          "label": "排序"
        },
        "list": {
          "label": "排序"
        }
      },
      "sections": {
        "edit": {
          "label": "详情分区"
        },
        "list": {
          "label": "详情分区"
        }
      },
      "contentImage": {
        "edit": {
          "label": "内容图片"
        },
        "list": {
          "label": "内容图片"
        }
      },
      "seo": {
        "edit": {
          "label": "SEO"
        },
        "list": {
          "label": "SEO"
        }
      }
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "string",
      "unique": true
    },
    "team": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::team.team",
      "inversedBy": "careers"
    },
    "employmentType": {
      "type": "string"
    },
    "locations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::location.location",
      "inversedBy": "careers"
    },
    "workModel": {
      "type": "enumeration",
      "enum": [
        "onsite",
        "hybrid",
        "remote"
      ],
      "default": "onsite",
      "required": true
    },
    "postedAt": {
      "type": "datetime"
    },
    "expiresAt": {
      "type": "datetime"
    },
    "experienceLevel": {
      "type": "enumeration",
      "enum": [
        "intern",
        "junior",
        "mid",
        "senior",
        "lead",
        "director"
      ]
    },
    "sortOrder": {
      "type": "integer",
      "default": 999
    },
    "sections": {
      "type": "component",
      "repeatable": true,
      "component": "shared.rich-text-section"
    },
    "contentImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
