    },
    "team": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::team.team",
      "inversedBy": "careers"
    },
    "employmentType": {
      "type": "string"
    },
    "locations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::location.location",
      "inversedBy": "careers"
    },
    "postedAt": {
      "type": "datetime"
    },
    "expiresAt": {
      "type": "datetime"
    },
    "isDraft": {
      "type": "boolean",
      "default": false
    }
  }
}
