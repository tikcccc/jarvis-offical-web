{
    "kind": "collectionType",
    "collectionName": "case_study_categories",
    "info": {
        "singularName": "case-study-category",
        "pluralName": "case-study-categories",
        "displayName": "Case Study Category",
        "description": "Categories for case studies"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true
        },
        "description": {
            "type": "text"
        },
        "color": {
            "type": "string"
        },
        "sortOrder": {
            "type": "integer",
            "default": 999
        },
        "caseStudies": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::case-study.case-study",
            "mappedBy": "category"
        }
    }
}
