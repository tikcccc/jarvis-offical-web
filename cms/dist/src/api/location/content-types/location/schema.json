{
    "kind": "collectionType",
    "collectionName": "locations",
    "info": {
        "singularName": "location",
        "pluralName": "locations",
        "displayName": "Location",
        "description": "Office locations for careers"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true
        },
        "address": {
            "type": "text"
        },
        "careers": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::career.career",
            "mappedBy": "locations"
        }
    }
}
