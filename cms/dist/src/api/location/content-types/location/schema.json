{
    "kind": "collectionType",
    "collectionName": "locations",
    "info": {
        "singularName": "location",
        "pluralName": "locations",
        "displayName": "23 招聘｜地点",
        "description": "招聘页使用的办公地点"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "config": {
        "settings": {
            "bulkable": true,
            "filterable": true,
            "mainField": "title",
            "defaultSortBy": "title",
            "defaultSortOrder": "ASC",
            "pageSize": 10,
            "searchable": true,
            "relationOpenMode": "modal"
        },
        "layouts": {
            "list": [
                "title",
                "address",
                "slug"
            ]
        },
        "metadatas": {
            "title": {
                "edit": {
                    "label": "名称"
                },
                "list": {
                    "label": "名称"
                }
            },
            "slug": {
                "edit": {
                    "label": "URL 标识",
                    "description": "用于页面链接；可留空，保存时会自动生成如 location-1 的值，也可手动覆写"
                },
                "list": {
                    "label": "URL 标识"
                }
            },
            "address": {
                "edit": {
                    "label": "地址"
                },
                "list": {
                    "label": "地址"
                }
            },
            "careers": {
                "edit": {
                    "label": "职位",
                    "visible": false
                },
                "list": {
                    "label": "职位"
                }
            }
        }
    },
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "string",
            "unique": true
        },
        "address": {
            "type": "text"
        },
        "careers": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::career.career",
            "mappedBy": "locations"
        }
    }
}
