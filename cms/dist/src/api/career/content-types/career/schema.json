{
    "kind": "collectionType",
    "collectionName": "careers",
    "info": {
        "singularName": "career",
        "pluralName": "careers",
        "displayName": "Career",
        "description": "Career positions for the public website"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true
        },
        "team": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::team.team",
            "inversedBy": "careers"
        },
        "employmentType": {
            "type": "string"
        },
        "locations": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::location.location",
            "inversedBy": "careers"
        },
        "workModel": {
            "type": "enumeration",
            "enum": [
                "onsite",
                "hybrid",
                "remote"
            ],
            "default": "onsite",
            "required": true
        },
        "postedAt": {
            "type": "datetime"
        },
        "expiresAt": {
            "type": "datetime"
        },
        "experienceLevel": {
            "type": "enumeration",
            "enum": [
                "intern",
                "junior",
                "mid",
                "senior",
                "lead",
                "director"
            ]
        },
        "sortOrder": {
            "type": "integer",
            "default": 999
        },
        "sections": {
            "type": "component",
            "repeatable": true,
            "component": "shared.rich-text-section"
        },
        "contentImage": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images"
            ]
        },
        "seo": {
            "type": "component",
            "repeatable": false,
            "component": "shared.seo"
        }
    }
}
