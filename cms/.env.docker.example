# Optional overrides for deploy/docker/docker-compose.local.yml
# Usage:
#   cp cms/.env.docker.example cms/.env.docker
#   docker compose -f deploy/docker/docker-compose.local.yml up --build

HOST=0.0.0.0
PORT=1337
NODE_ENV=production

APP_KEYS=localKey1,localKey2,localKey3,localKey4
API_TOKEN_SALT=local-api-token-salt
ADMIN_JWT_SECRET=local-admin-jwt-secret
TRANSFER_TOKEN_SALT=local-transfer-token-salt
ENCRYPTION_KEY=local-encryption-key-32-char
JWT_SECRET=local-jwt-secret

DATABASE_CLIENT=mysql
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_NAME=isbim_cms
DATABASE_USERNAME=isbim
DATABASE_PASSWORD=123456
DATABASE_SSL=false
