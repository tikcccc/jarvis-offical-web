# Production Environment Variables
# isBIM Official Web - Production Configuration

# Sanity CMS

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://www.isbim.com.hk

# Media CDN (videos) - Hong Kong Node (International)
NEXT_PUBLIC_VIDEO_CDN_URL=https://posix-jarvis-hk.obs.ap-southeast-1.myhuaweicloud.com/jarvis/share/video
# Feature Videos CDN (product detail clips)
NEXT_PUBLIC_FEATURE_VIDEO_CDN_URL=https://posix-jarvis-hk.obs.ap-southeast-1.myhuaweicloud.com/jarvis/share/isbim-website-assets

# Token for authenticated requests (keep this secret!)

# Sanity Webhook Secret (required for ISR revalidation)
# Webhook temporarily not deployed; keep empty or set when enabling

# Resend API Key for email sending
# Replace with production API key in deployment platform
RESEND_API_KEY=re_PxruYaVG_3mmLV3k3sZx2H7WCiA36fbW6

# Contact form internal notification recipient
CONTACT_EMAIL_TO=solution@isbim.com.hk

# Email sender addresses
# IMPORTANT: Production must use verified domain (@isbim.com.hk)
# Verify domain at https://resend.com/domains before deployment
# Configure DNS records (SPF, DKIM, DMARC) as instructed by Resend
EMAIL_FROM_INTERNAL=isBIM Contact Form <noreply@isbim.com.hk>
EMAIL_FROM_USER=isBIM <noreply@isbim.com.hk>

# Brevo API Key (backup email provider)
# Get your API key from: https://app.brevo.com/settings/keys/api
# Optional - only needed if using Brevo as backup
BREVO_API_KEY=

# Email Provider Selection
# Options: resend (default) | brevo
# Set in deployment platform environment variables
EMAIL_PROVIDER=resend

STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=5b1247ecdc65bd48a854497b7f1e2cdef46cf433f541a4228400206e061be5c8468f05cdf1473020d0632996351bd8e8de4c469b41de77ef68d6382e6b9b23383f8d49199016e4eb0776d19b61b11a26886a98eb42c47bfdc834a4133d7944703c43ebd5e88907682b5650e8feb3d1504f559cb4c85a376414a94ea3475d514e
