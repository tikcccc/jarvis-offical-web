# Optional overrides for deploy/docker/docker-compose.local.yml
# Usage:
#   cp web/.env.local.docker.example web/.env.local.docker
#   export WEB_STRAPI_API_TOKEN="<token>"  # if Strapi APIs are not public
#   docker compose -f deploy/docker/docker-compose.local.yml up --build

NEXT_PUBLIC_SITE_URL=http://localhost:3000
STRAPI_URL=http://cms:1337
# Docker compose local stack: use service DNS so the web container can reach cms.
NEXT_PUBLIC_STRAPI_URL=http://cms:1337
# Leave empty to use web/public local assets (/images, /videos) in local testing.
NEXT_PUBLIC_MEDIA_URL=

# Optional: required when Strapi permissions are private
WEB_STRAPI_API_TOKEN=
WEB_STRAPI_WEBHOOK_SECRET=local-webhook-secret

# Optional media overrides
NEXT_PUBLIC_VIDEO_CDN_URL=
NEXT_PUBLIC_FEATURE_VIDEO_CDN_URL=

# Optional search engine verification / push
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
BAIDU_SITE_VERIFICATION=
BAIDU_PUSH_TOKEN=

# Optional email settings for contact form server action
RESEND_API_KEY=
BREVO_API_KEY=
EMAIL_PROVIDER=resend
CONTACT_EMAIL_TO=solution@isbim.com.hk
EMAIL_FROM_INTERNAL=isBIM Contact Form <noreply@example.com>
EMAIL_FROM_USER=isBIM <noreply@example.com>
